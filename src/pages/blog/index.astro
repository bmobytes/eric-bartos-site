---
import BaseLayout from '../../layouts/BaseLayout.astro';

const postModules = import.meta.glob('../../content/blog/*.md', { eager: true });
const posts = Object.values(postModules)
  .map((mod: any) => ({
    frontmatter: mod.frontmatter,
    slug: mod.file.split('/').pop()?.replace('.md', ''),
  }))
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Bartos Lab Logs" description="Infrastructure notes, project write-ups, and lab experiments from Eric Bartos.">
  <div class="blog-wrapper">
    <h1>Bartos Lab Logs</h1>
    <p class="blog-subtitle">Infrastructure notes, project write-ups, and lab experiments.</p>

    {posts.length === 0 ? (
      <p>No posts yet — check back soon.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <span class="post-date">{new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            <h2><a href={`${base}/blog/${post.slug}/`}>{post.frontmatter.title}</a></h2>
            {post.frontmatter.description && <p>{post.frontmatter.description}</p>}
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
