---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const postModules = import.meta.glob('../../content/blog/*.md', { eager: true });
  return Object.values(postModules).map((mod: any) => {
    const slug = mod.file.split('/').pop()?.replace('.md', '');
    return {
      params: { slug },
      props: { post: mod },
    };
  });
}

const { post } = Astro.props;
const { title, date, description } = post.frontmatter;
const Content = post.Content;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={`${title} — Bartos Lab Logs`} description={description}>
  <article>
    <header style="margin-bottom:2rem;">
      <span class="post-date">{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
      <h1 style="margin-top:0.25rem;">{title}</h1>
    </header>
    <Content />
  </article>
  <p style="margin-top:3rem;">
    <a href={`${base}/blog/`}>&larr; Back to Lab Logs</a>
  </p>
</BaseLayout>
