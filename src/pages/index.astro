---
import BaseLayout from '../layouts/BaseLayout.astro';
import resume from '../data/resume.json';

const { basics } = resume;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Eric Bartos — Senior Infrastructure Architect">
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-profile">
        <div class="photo-placeholder">
          <span>Photo</span>
          <span class="photo-sub">coming soon</span>
        </div>
        <div class="hero-text">
          <span class="hero-eyebrow">Senior Infrastructure Architect</span>
          <h1>{basics.name}</h1>
          <p class="hero-summary">{basics.summary}</p>
          <div class="hero-actions">
            <a href={`${base}/resume/`} class="btn btn-primary">Resume</a>
            <a href={`mailto:${basics.email}`} class="btn btn-secondary">Get in Touch</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
