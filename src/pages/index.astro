---
import BaseLayout from '../layouts/BaseLayout.astro';
import resume from '../data/resume.json';

const { basics } = resume;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Eric Bartos — Senior Infrastructure Architect">
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <span class="hero-eyebrow">Senior Infrastructure Architect</span>
        <h1>{basics.name}</h1>
        <p class="hero-summary">{basics.summary}</p>
        <div class="hero-actions">
          <a href={`${base}/resume/`} class="btn btn-primary">View Resume</a>
          <a href={`mailto:${basics.email}`} class="btn btn-secondary">Get in Touch</a>
        </div>
      </div>
      <div class="hero-photo">
        <div class="photo-placeholder" title="Headshot coming soon">
          <span>Photo</span>
          <span class="photo-sub">coming soon</span>
        </div>
      </div>
    </div>
  </section>

  <section class="entry-section">
    <div class="entry-inner">
      <div class="entry-card">
        <span class="entry-eyebrow">Writing &amp; Notes</span>
        <h2 class="entry-title">Bartos Lab Logs</h2>
        <p class="entry-desc">Infrastructure deep-dives, lab experiments, and project write-ups from the home rack and beyond.</p>
        <a href={`${base}/blog/`} class="entry-link">Browse the logs &rarr;</a>
      </div>
      <div class="entry-card">
        <span class="entry-eyebrow">Background</span>
        <h2 class="entry-title">Work &amp; Experience</h2>
        <p class="entry-desc">Cloud-native infrastructure, automation, and platform reliability — see the full picture on the resume.</p>
        <a href={`${base}/resume/`} class="entry-link">View full resume &rarr;</a>
      </div>
    </div>
  </section>
</BaseLayout>
